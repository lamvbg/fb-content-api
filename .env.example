# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fb_fanpage

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/facebook/callback
FACEBOOK_GRAPH_API_URL=https://graph.facebook.com/v21.0

# X (Twitter)
X_COOKIES_FILE=cookies.txt

# Grok (xAI) LLM
XAI_API_KEY=your-xai-api-key
XAI_MODEL=grok-3-mini

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
